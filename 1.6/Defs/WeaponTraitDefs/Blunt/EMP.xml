<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Blunt. Head — an electromagnetic discharge on impact, the melee port of Odyssey's ranged EMPRounds
       (same forced UniqueWeapon_EMP tint, same EMP DamageDef). Realised through our generic on-hit path:
       MeleeOnHitEffect_ExtraDamage stacks an extra Core "EMP" hit (amount 4) every wounding blow. EMP carries
       causeStun, harmsHealth=false, and stuns ONLY non-flesh pawns (StunHandler.CanBeStunnedByDamage), so it's
       a pure anti-mechanoid effect — no injury, no effect on flesh. The stun fires for free: every
       Thing.TakeDamage on a spawned pawn reaches Pawn_HealthTracker.PreApplyDamage → stunner.Notify_DamageApplied,
       the same path Odyssey's EMPRounds extraDamages rides — so no new C#. No chance gate: EMP's own
       stunAdaptationTicks (2200t) self-limits a chain (first hit stuns + starts adaptation; later hits read
       "Adapted" until it lapses), exactly like the ranged version. Rarer (commonality 0.5, matching
       UMW_Monomolecular). Shares the "Head" token with UMW_Concussive: both are the blunt head's on-hit
       incapacitation effect (kinetic stun vs electromagnetic stun), so a weapon gets at most one. Forces the
       UniqueWeapon_EMP tint onto COLOUR ONE (the red-masked accent, via vanilla forcedColor), so it also tags
       "Color" and can't share a weapon with the Gold/Jade inlays — mirrors EMPRounds' AmmoType+Color and our
       own UMW_Envenomed (Coating+Color). -->
  <WeaponTraitDef>
    <defName>UMW_EMP</defName>
    <label>EMP</label>
    <description>The head carries embedded EMP capacitors that discharge on impact, temporarily disabling electronics and mechanoids.</description>
    <commonality>0.5</commonality>
    <weaponCategory>UMW_Blunt</weaponCategory>
    <exclusionTags>
      <li>Head</li>
      <li>Color</li>
    </exclusionTags>
    <forcedColor>UniqueWeapon_EMP</forcedColor>
    <statOffsets>
      <MarketValue>75</MarketValue>
    </statOffsets>
    <traitAdjectives>
      <li>EMP</li>
      <li>electric</li>
      <li>shocking</li>
    </traitAdjectives>
    <modExtensions>
      <li Class="UniqueMeleeWeapons.MeleeTraitEffectExtension">
        <onHitEffects>
          <li Class="UniqueMeleeWeapons.MeleeOnHitEffect_ExtraDamage">
            <def>EMP</def>
            <amount>4</amount>
            <armorPenetration>0</armorPenetration>
          </li>
        </onHitEffects>
      </li>
    </modExtensions>
  </WeaponTraitDef>

</Defs>
