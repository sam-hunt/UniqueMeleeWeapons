<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Blunt. The signature blunt effect, by design: a solid blow rings resonant shock through armor
       and bone, briefly stunning the struck (60t @ 25%). The sole Blunt trait, which is fine — single-trait
       categories are allowed (Odyssey has several). Replaced the old UMW_Weighted (which duplicated this
       stun atop a heavy-head stat profile already owned by UMW_Heavy/HeadWeighted). The "Head" exclusion
       tag stays so any future blunt-head trait is mutually exclusive. -->
  <WeaponTraitDef>
    <defName>UMW_Concussive</defName>
    <label>concussive</label>
    <description>This weapon is balanced so that a solid blow rings resonant shock through armor and bone — a clean strike briefly stuns the struck.</description>
    <commonality>1</commonality>
    <weaponCategory>UMW_Blunt</weaponCategory>
    <exclusionTags>
      <li>Head</li>
    </exclusionTags>
    <traitAdjectives>
      <li>concussive</li>
      <li>ringing</li>
      <li>stunning</li>
      <li>thunderous</li>
    </traitAdjectives>
    <modExtensions>
      <li Class="UniqueMeleeWeapons.MeleeTraitEffectExtension">
        <onHitEffects>
          <li Class="UniqueMeleeWeapons.MeleeOnHitEffect_Stun">
            <ticks>60</ticks>
            <chance>0.25</chance>
          </li>
        </onHitEffects>
      </li>
    </modExtensions>
  </WeaponTraitDef>

</Defs>
