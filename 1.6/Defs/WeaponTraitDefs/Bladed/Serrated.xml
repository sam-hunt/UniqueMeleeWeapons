<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Bladed. Edge — the jagged-edge bleed. MeleeDamageConversionExtension reroutes the base Cut to
       the bleedier, scar-prone UMW_Cut_Ragged. MeleeToolModExtension then shapes per-tool damage: the Cut
       deals -10% (a sawtooth edge slashes less cleanly) while the Stab deals +10%, because on a thrust the
       same teeth catch and tear flesh on the way out — a nastier exit wound (the boost is the serration's
       after-effect, NOT a finer point). Unlike the old weapon-wide -10% MeleeWeapon_DamageMultiplier this
       no longer reduces armor pen; the ragged bleed is the whole tradeoff. The Edge tag keeps it mutually
       exclusive with Razored/Monomolecular. -->
  <WeaponTraitDef>
    <defName>UMW_Serrated</defName>
    <label>serrated</label>
    <description>The edge is cut into vicious teeth that tear ragged, freely bleeding wounds. On a thrust the same teeth catch and rip flesh as the blade is drawn back.</description>
    <commonality>1</commonality>
    <weaponCategory>UMW_Bladed</weaponCategory>
    <exclusionTags>
      <li>Edge</li>
    </exclusionTags>
    <statOffsets>
      <Beauty>-2</Beauty>
      <MarketValue>30</MarketValue> <!-- nasty-wound w/ Cut-damage tradeoff -->
    </statOffsets>
    <traitAdjectives>
      <li>serrated</li>
      <li>jagged</li>
      <li>vicious</li>
      <li>sawtooth</li>
    </traitAdjectives>
    <modExtensions>
      <li Class="UniqueMeleeWeapons.MeleeDamageConversionExtension">
        <conversions>
          <li>
            <from>Cut</from>
            <to>UMW_Cut_Ragged</to>
          </li>
        </conversions>
      </li>
      <li Class="UniqueMeleeWeapons.MeleeToolModExtension">
        <mods>
          <li>
            <capacities>
              <li>Cut</li>
            </capacities>
            <damageFactor>0.9</damageFactor>
          </li>
          <li>
            <capacities>
              <li>Stab</li>
            </capacities>
            <damageFactor>1.1</damageFactor>
          </li>
        </mods>
      </li>
    </modExtensions>
  </WeaponTraitDef>

</Defs>
