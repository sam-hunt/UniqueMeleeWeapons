<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Bladed. Edge — converts the weapon's normal Cut into a bleedier, scar-prone ragged cut
       (UMW_Cut_Ragged), traded against -10% MeleeWeapon_DamageMultiplier. That one stat drives both melee
       damage AND armor pen, so the trade is a single lever: less burst lethality + worse vs armor, balanced
       by ~2x bleeding and far more permanent scars. A conversion (no extra damage stacked), not a buff. -->
  <WeaponTraitDef>
    <defName>UMW_Serrated</defName>
    <label>serrated</label>
    <description>The edge is cut into vicious teeth that tear ragged, freely bleeding wounds — slow to close and quick to scar, though the jagged edge bites less cleanly and drives less force through armor.</description>
    <commonality>1</commonality>
    <weaponCategory>UMW_Bladed</weaponCategory>
    <exclusionTags>
      <li>Edge</li>
    </exclusionTags>
    <statOffsets>
      <Beauty>-2</Beauty>
    </statOffsets>
    <statFactors>
      <MeleeWeapon_DamageMultiplier>0.9</MeleeWeapon_DamageMultiplier>
    </statFactors>
    <traitAdjectives>
      <li>serrated</li>
      <li>jagged</li>
      <li>vicious</li>
      <li>sawtooth</li>
    </traitAdjectives>
    <modExtensions>
      <li Class="UniqueMeleeWeapons.MeleeDamageConversionExtension">
        <conversions>
          <li>
            <from>Cut</from>
            <to>UMW_Cut_Ragged</to>
          </li>
        </conversions>
      </li>
    </modExtensions>
  </WeaponTraitDef>

</Defs>
