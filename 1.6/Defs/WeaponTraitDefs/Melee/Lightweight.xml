<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Melee. Weight — lighter, quicker swing. The universal alone-able trait
       (canGenerateAlone defaults true); its adjectives guarantee every weapon can be named.
       Re-pointed port of Odyssey's Ranged "Lightweight" (deltas noted inline). -->
  <WeaponTraitDef>
    <defName>UMW_Lightweight</defName>
    <label>lightweight</label>
    <description>This weapon is much lighter than normal, quickening its swing.</description>
    <commonality>1</commonality>
    <weaponCategory>UMW_Melee</weaponCategory>
    <exclusionTags>
      <li>Weight</li>
    </exclusionTags>
    <statOffsets>
      <MarketValue>80</MarketValue> <!-- = Odyssey Lightweight -->
    </statOffsets>
    <statFactors>
      <Mass>0.7</Mass> <!-- Odyssey: ×0.75 -->
      <MeleeWeapon_CooldownMultiplier>0.9</MeleeWeapon_CooldownMultiplier> <!-- Odyssey: RangedWeapon_WarmupMultiplier -0.2 (inert on melee) -->
    </statFactors>
    <traitAdjectives>
      <li>light</li>
      <li>nimble</li>
      <li>quickdraw</li>
    </traitAdjectives>
  </WeaponTraitDef>

</Defs>
