    <commonality>1</commonality>
    <weaponCategory>UMW_Melee</weaponCategory>
    <exclusionTags>
      <li>Weight</li>
    </exclusionTags>
    <statFactors>
      <Mass>0.7</Mass>
      <MeleeWeapon_CooldownMultiplier>0.9</MeleeWeapon_CooldownMultiplier>
      <MarketValue>1.3</MarketValue>
    </statFactors>
    <traitAdjectives>
      <li>light</li>
      <li>nimble</li>
      <li>quickdraw</li>
    </traitAdjectives>
  </WeaponTraitDef>

</Defs>
