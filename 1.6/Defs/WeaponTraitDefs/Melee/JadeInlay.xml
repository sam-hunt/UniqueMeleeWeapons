<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Melee. Inlay — forces the UniqueWeapon_Jade accent colour (colour one / red mask).
       Add-on only (canGenerateAlone=false); shared "Color" exclusion tag = one inlay per weapon.
       Verbatim-equivalent port of Odyssey's Ranged "JadeInlay" — touches only category-agnostic
       stats (Beauty +10, MarketValue ×1.4, forcedColor), so values match Odyssey 1:1; reuses
       Odyssey's UniqueWeapon_* ColorDefs directly. -->
  <WeaponTraitDef>
    <defName>UMW_JadeInlay</defName>
    <label>jade inlay</label>
    <description>This weapon is adorned with jade. Traders will pay more for it.</description>
    <commonality>0.5</commonality>
    <canGenerateAlone>false</canGenerateAlone>
    <weaponCategory>UMW_Melee</weaponCategory>
    <exclusionTags>
      <li>Color</li>
    </exclusionTags>
    <forcedColor>UniqueWeapon_Jade</forcedColor>
    <statOffsets>
      <Beauty>10</Beauty>
    </statOffsets>
    <statFactors>
      <MarketValue>1.4</MarketValue>
    </statFactors>
    <traitAdjectives>
      <li>jade</li>
    </traitAdjectives>
  </WeaponTraitDef>

</Defs>
