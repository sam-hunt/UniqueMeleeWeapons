<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Melee. Inlay — forces the UniqueWeapon_Gold accent colour (colour one / red mask).
       Add-on only (canGenerateAlone=false); shared "Color" exclusion tag = one inlay per weapon.
       Verbatim-equivalent port of Odyssey's Ranged "GoldInlay" — touches only category-agnostic
       stats (Beauty +20, MarketValue ×2, forcedColor), so values match Odyssey 1:1; reuses
       Odyssey's UniqueWeapon_* ColorDefs directly. -->
  <WeaponTraitDef>
    <defName>UMW_GoldInlay</defName>
    <label>gold inlay</label>
    <description>This weapon is inlaid with gold. Traders will pay more for it.</description>
    <commonality>0.5</commonality>
    <canGenerateAlone>false</canGenerateAlone>
    <weaponCategory>UMW_Melee</weaponCategory>
    <exclusionTags>
      <li>Color</li>
    </exclusionTags>
    <forcedColor>UniqueWeapon_Gold</forcedColor>
    <statOffsets>
      <Beauty>20</Beauty>
    </statOffsets>
    <statFactors>
      <MarketValue>2</MarketValue>
    </statFactors>
    <traitAdjectives>
      <li>gold</li>
      <li>golden</li>
    </traitAdjectives>
  </WeaponTraitDef>

</Defs>
