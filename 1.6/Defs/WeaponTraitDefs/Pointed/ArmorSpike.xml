<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Pointed. Point shape — a reinforced spike that drives the thrust through heavy armor. Realised
       via MeleeToolModExtension flooring the Stab tool's armor penetration to 0.8 (no extra hit, no damage
       change — the point itself just punches through). Distinct from NeedlePoint, which is a coupled
       damage+AP buff with a hit-chance cost; the shared "Point" tag keeps the two shapes mutually
       exclusive. -->
  <WeaponTraitDef>
    <defName>UMW_ArmorSpike</defName>
    <label>armor spike</label>
    <description>A reinforced spike drives the point through plate and carapace that would turn a lesser thrust.</description>
    <commonality>1</commonality>
    <weaponCategory>UMW_Pointed</weaponCategory>
    <exclusionTags>
      <li>Point</li>
    </exclusionTags>
    <statOffsets>
      <MarketValue>40</MarketValue> <!-- cf. PiercingRounds -->
    </statOffsets>
    <traitAdjectives>
      <li>lancing</li>
      <li>armorbane</li>
      <li>punching</li>
    </traitAdjectives>
    <modExtensions>
      <li Class="UniqueMeleeWeapons.MeleeToolModExtension">
        <mods>
          <li>
            <capacities>
              <li>Stab</li>
            </capacities>
            <armorPenetrationFloor>0.8</armorPenetrationFloor>
          </li>
        </mods>
      </li>
    </modExtensions>
  </WeaponTraitDef>

</Defs>
