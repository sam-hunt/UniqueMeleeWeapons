<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Pointed. Point shape — a fine needle that concentrates a thrust into a flat passive buff to
       melee damage AND armor penetration (both ride MeleeWeapon_DamageMultiplier — there is no separate
       melee AP stat), traded against a slight hit-chance penalty (a delicate point is less forgiving to
       land). DECISION: unlike UMW_HeadWeighted (whose incidental AP we neutralize), we deliberately KEEP
       the coupling here — a finer point genuinely drives deeper, so the AP riding along is the point of
       the trait. A pure-stat tradeoff, distinct from ArmorSpike's pure Stab-AP floor; shared "Point" tag
       keeps the two shape traits mutually exclusive. -->
  <WeaponTraitDef>
    <defName>UMW_NeedlePoint</defName>
    <label>needle point</label>
    <description>Tapered to a fine needle, the point concentrates the full force of a thrust onto a single spot — driving deeper and biting through armor, though so slender a point is less forgiving to land cleanly.</description>
    <commonality>1</commonality>
    <weaponCategory>UMW_Pointed</weaponCategory>
    <exclusionTags>
      <li>Point</li>
    </exclusionTags>
    <statOffsets>
      <MarketValue>50</MarketValue> <!-- damage buff w/ hit-chance cost -->
    </statOffsets>
    <statFactors>
      <MeleeWeapon_DamageMultiplier>1.2</MeleeWeapon_DamageMultiplier>
    </statFactors>
    <equippedStatOffsets>
      <MeleeHitChance>-0.1</MeleeHitChance>
    </equippedStatOffsets>
    <traitAdjectives>
      <li>needle</li>
      <li>needling</li>
      <li>hypodermic</li>
    </traitAdjectives>
  </WeaponTraitDef>

</Defs>
