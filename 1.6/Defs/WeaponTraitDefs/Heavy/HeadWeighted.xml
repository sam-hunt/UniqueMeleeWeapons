<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- UMW_Heavy. Swing profile — slow but devastating. The +30% MeleeWeapon_DamageMultiplier is the
       damage payload; because that one stat also scales armor pen, it would inflate AP as a side effect.
       We don't want HeadWeighted to be a stealth armor-piercer (AP is meant to be owned by the dedicated
       floor traits), so MeleeToolModExtension multiplies AP back down by 1/1.3 on every tool, leaving the
       damage boost but a neutral AP.
       GOTCHA: the 0.7692 factor is 1/1.3 — if the MeleeWeapon_DamageMultiplier below changes, update the
       factor to match (1 / newMultiplier). -->
  <WeaponTraitDef>
    <defName>UMW_HeadWeighted</defName>
    <label>head-weighted</label>
    <description>Mass is gathered toward the striking end so each swing lands with devastating force, though it is slower to recover.</description>
    <commonality>1</commonality>
    <weaponCategory>UMW_Heavy</weaponCategory>
    <exclusionTags>
      <li>SwingProfile</li>
    </exclusionTags>
    <statOffsets>
      <MarketValue>60</MarketValue> <!-- damage archetype, cf. HighPowerRounds (offset, though its combat effect is a factor) -->
    </statOffsets>
    <statFactors>
      <MeleeWeapon_DamageMultiplier>1.3</MeleeWeapon_DamageMultiplier>
      <MeleeWeapon_CooldownMultiplier>1.18</MeleeWeapon_CooldownMultiplier>
    </statFactors>
    <traitAdjectives>
      <li>devastating</li>
      <li>mighty</li>
      <li>ponderous</li>
    </traitAdjectives>
    <modExtensions>
      <li Class="UniqueMeleeWeapons.MeleeToolModExtension">
        <mods>
          <li>
            <armorPenetrationFactor>0.7692</armorPenetrationFactor>
          </li>
        </mods>
      </li>
    </modExtensions>
  </WeaponTraitDef>

</Defs>
