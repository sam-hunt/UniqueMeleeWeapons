<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Base-damage target for the UMW_Serrated trait. The DamageConversion postfix reroutes the weapon's
       normal Cut hit to this in place (no extra damage stacked) — see the on-hit-effects note in CLAUDE.md.
       Faithful clone of Core's Cut (keeps DamageWorker_Cut cleave, Sharp armor, the overkill/cleave curves),
       differing only in routing the wound to the bleedier, scar-prone UMW_Cut_Ragged injury hediff of the
       same name (mirrors vanilla's Cut DamageDef -> Cut hediff pairing). Cloned, NOT ParentName="Cut":
       Core's Cut carries no Name= so it can't be a parent (same gotcha as Stab_Tox). Label stays "cut" to
       keep the combat log clean; the "ragged" flavor rides the injury hediff's label. -->
  <DamageDef>
    <defName>UMW_Cut_Ragged</defName>
    <label>cut</label>
    <workerClass>DamageWorker_Cut</workerClass>
    <externalViolence>true</externalViolence>
    <deathMessage>{0} has been cut to death.</deathMessage>
    <hediff>UMW_Cut_Ragged</hediff>
    <hediffSkin>UMW_Cut_Ragged</hediffSkin>
    <hediffSolid>Crack</hediffSolid>
    <harmAllLayersUntilOutside>true</harmAllLayersUntilOutside>
    <impactSoundType>Slice</impactSoundType>
    <armorCategory>Sharp</armorCategory>
    <overkillPctToDestroyPart>0~0.1</overkillPctToDestroyPart>
    <cutExtraTargetsCurve>
      <points>
        <li>0, 0</li>
        <li>0.6, 1</li>
        <li>0.9, 2</li>
        <li>1, 3</li>
      </points>
    </cutExtraTargetsCurve>
    <cutCleaveBonus>1.4</cutCleaveBonus>
  </DamageDef>

</Defs>
